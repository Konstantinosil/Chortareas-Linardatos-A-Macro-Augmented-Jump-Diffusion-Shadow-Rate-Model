        "\n",
        "def _irf_endog_names(irf):\n",
        "    \"\"\"Return VAR variable names from statsmodels IRAnalysis objects.\n",
        "\n",
        "    Different statsmodels versions store names in different places:\n",
        "    older versions expose irf.model.endog_names, while newer VARResults\n",
        "    objects typically expose irf.model.names.\n",
        "    \"\"\"\n",
        "    candidates = [\n",
        "        irf,\n",
        "        getattr(irf, \"model\", None),\n",
        "        getattr(getattr(irf, \"model\", None), \"model\", None),\n",
        "    ]\n",
        "    for obj in candidates:\n",
        "        if obj is None:\n",
        "            continue\n",
        "        for attr in (\"endog_names\", \"names\"):\n",
        "            if hasattr(obj, attr):\n",
        "                names = getattr(obj, attr)\n",
        "                if names is not None:\n",
        "                    return list(names)\n",
        "    raise AttributeError(\"Could not find endogenous variable names in IRF object.\")\n",
        "\n",
        "\n",
        "def calculate_cumulative_irf(irf, periods=20):\n",
        "    cumulative_irfs = {}\n",
        "    names = _irf_endog_names(irf)\n",
        "    for i, response_var in enumerate(names):\n",
        "        for j, impulse_var in enumerate(names):\n",
        "            cumulative_irfs[f\"{response_var} -> {impulse_var}\"] = np.sum(\n",
        "                np.abs(irf.orth_irfs[:periods, i, j])\n",
        "            )\n",
        "    return cumulative_irfs\n",
        "\n",
        "\n",
        "cumulative_irf_your_shadow_us = calculate_cumulative_irf(irf_your_shadow_us)\n",
        "cumulative_irf_wu_xia_us = calculate_cumulative_irf(irf_wu_xia_us)\n",
        "\n",
        "comparison_df = pd.DataFrame(\n",
        "    {\n",
        "        \"MAJD (United States)\": cumulative_irf_your_shadow_us,\n",
        "        \"WX (United States)\": cumulative_irf_wu_xia_us,\n",
        "    }\n",
        ").T\n",
        "\n",
        "comparison_df.loc[\"Difference\"] = (\n",
        "    comparison_df.loc[\"MAJD (United States)\"] - comparison_df.loc[\"WX (United States)\"]\n",
        ")\n",
