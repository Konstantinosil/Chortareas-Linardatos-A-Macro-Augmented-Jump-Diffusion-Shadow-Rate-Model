        "        Path.cwd() / filename,\n",
        "        Path.cwd() / \"data\" / filename,\n",
        "        Path.cwd() / \"data\" / \"raw\" / filename,\n",
        "        Path(\"/content\") / filename,\n",
        "        Path(\"/content\") / \"data\" / filename,\n",
        "        Path(\"/content\") / \"data\" / \"raw\" / filename,\n",
        "        Path(\"/mnt/data\") / filename,\n",
        "        Path(\"/mnt/data\") / \"data\" / filename,\n",
        "        Path(\"/mnt/data\") / \"data\" / \"raw\" / filename,\n",
        "    ]\n",
        "    for p in candidates:\n",
        "        if p.exists():\n",
        "            return p\n",
        "\n",
        "    # Last resort: shallow recursive search in common roots.\n",
        "    for root in [Path.cwd(), Path(\"/content\"), Path(\"/mnt/data\")]:\n",
        "        if root.exists():\n",
        "            hits = list(root.rglob(filename))\n",
        "            if hits:\n",
        "                return hits[0]\n",
        "\n",
        "    raise FileNotFoundError(\n",
        "        f\"Could not find {filename}. Put it next to this script, in data/raw, or in /content.\"\n",
        "    )\n",
        "\n",
        "\n",
        "DATA_XLSX = find_file(\"data shadow new us.xlsx\")\n",
        "CGG_ZIP = find_file(\"Replication codes - Cascaldi-Garcia and Galvao JMCB.zip\")\n",
        "\n",
        "print(f\"Using master workbook: {DATA_XLSX}\")\n",
        "print(f\"Using CGG zip file:    {CGG_ZIP}\")\n",
        "\n",
        "\n",
        "# =============================================================================\n",
        "# 1. Helpers for the master U.S. workbook\n",
        "# =============================================================================\n",
        "\n",
        "xls = pd.ExcelFile(DATA_XLSX)\n",
        "\n",
        "\n",
        "def _prep(sheet, cols):\n",
        "    \"\"\"\n",
        "    Read a two-column sheet from the master workbook.\n",
        "\n",
        "    All master sheets are expected to have:\n",
        "        row 1: country label, e.g. US\n",
        "        row 2: Date | variable name\n",
        "        row 3+: data\n",
        "\n",
        "    This preserves the original header=1 loading convention.\n",
        "    \"\"\"\n",
        "    df = pd.read_excel(xls, sheet_name=sheet, header=1)\n",
        "    df = df.iloc[:, :len(cols)].copy()\n",
        "    df.columns = cols\n",
        "    df[\"Date\"] = pd.to_datetime(df[\"Date\"], dayfirst=True, errors=\"coerce\")\n",
        "    for c in cols:\n",
        "        if c != \"Date\":\n",
        "            df[c] = pd.to_numeric(df[c], errors=\"coerce\")\n",
        "    return df.dropna(subset=[\"Date\"]).set_index(\"Date\").sort_index()\n",
        "\n",
        "\n",
        "def _series_from_master(sheet, output_col):\n",
        "    \"\"\"Convenience wrapper for one Date + one value sheet.\"\"\"\n",
        "    return _prep(sheet, [\"Date\", output_col])\n",
        "\n",
        "\n",
        "# =============================================================================\n",
        "# 2. MAJD shadow-rate construction\n",
        "#    Original methodology preserved.\n",
        "# =============================================================================\n",
        "\n",
        "ser = {\n",
        "    \"SR\":  _prep(\"Shadow Rates US\",             [\"Date\", \"SR US\"]),\n",
        "    \"INF\": _prep(\"Inflation Data US\",           [\"Date\", \"INF US\"]),\n",
        "    \"UN\":  _prep(\"Unemployment Data US\",        [\"Date\", \"UNEM US\"]),\n",
        "    \"CDS\": _prep(\"Sovereign CDS Spreads US\",    [\"Date\", \"CDS US\"]),\n",
        "    \"GDP\": _prep(\"Real GDP US\",                 [\"Date\", \"GDP US\"]),\n",
        "    \"EX\":  _prep(\"Exchange Rates US\",           [\"Date\", \"EX US\"]),\n",
        "    \"3M\":  _prep(\"3M\",                          [\"Date\", \"3M US\"]),\n",
        "    \"6M\":  _prep(\"6M\",                          [\"Date\", \"6M US\"]),\n",
        "    \"1Y\":  _prep(\"1Y\",                          [\"Date\", \"1Y US\"]),\n",
        "    \"2Y\":  _prep(\"2Y\",                          [\"Date\", \"2Y US\"]),\n",
        "    \"5Y\":  _prep(\"5Y\",                          [\"Date\", \"5Y US\"]),\n",
        "    \"7Y\":  _prep(\"7Y\",                          [\"Date\", \"7Y US\"]),\n",
        "    \"10Y\": _prep(\"10Y\",                         [\"Date\", \"10Y US\"]),\n",
        "    \"30Y\": _prep(\"30Y\",                         [\"Date\", \"30Y US\"]),\n",
        "}\n",
        "\n",
        "df = pd.concat(ser.values(), axis=1).interpolate(\"linear\")\n",
        "\n",
        "macro = [\"INF US\", \"UNEM US\", \"EX US\", \"CDS US\", \"GDP US\"]\n",
        "ylds = [\"3M US\", \"6M US\", \"1Y US\", \"2Y US\", \"5Y US\", \"7Y US\", \"10Y US\", \"30Y US\"]\n",
        "\n",
        "df = df.dropna(subset=[\"SR US\"] + macro + ylds)\n",
        "\n",
        "y_df = df[ylds].copy()\n",
        "m_df = df[macro].copy()\n",
        "\n",
        "# -----------------------------\n",
        "# Stationarity / diagnostic tests\n",
        "# -----------------------------\n",
        "var_list = ylds + macro\n",
        "tbl_station, tbl_ac, tbl_arch = [], [], []\n",
        "\n",
        "for v in var_list:\n",
        "    s0 = df[v].dropna()\n",
        "    adf_raw = adfuller(s0, autolag=\"AIC\")\n",
        "    is_stat = adf_raw[1] < 0.05\n",
        "\n",
        "    if is_stat:\n",
        "        s = s0.copy()\n",
        "        trans = \"level\"\n",
        "        adf = adf_raw\n",
        "    else:\n",
        "        s = s0.diff().dropna()\n",
        "        trans = \"diff\"\n",
        "        adf = adfuller(s, autolag=\"AIC\")\n",
        "\n",
        "    lb = acorr_ljungbox(s, lags=[10], return_df=True)\n",
        "    arch = het_arch(s, nlags=10)\n",
        "\n",
        "    tbl_station.append([v, trans, adf[0], adf[1]])\n",
        "    tbl_ac.append([v, lb[\"lb_stat\"].iat[0], lb[\"lb_pvalue\"].iat[0]])\n",
        "    tbl_arch.append([v, arch[0], arch[1]])\n",
        "\n",
        "print(\"\\n=== ADF stationarity test ===\")\n",
        "display(pd.DataFrame(tbl_station, columns=[\"Var\", \"Transform\", \"ADF stat\", \"p-value\"]).round(4))\n",
        "\n",
        "print(\"\\n=== Ljung-Box Q(10) autocorrelation test ===\")\n",
        "display(pd.DataFrame(tbl_ac, columns=[\"Var\", \"LB stat\", \"p-value\"]).round(4))\n",
        "\n",
        "print(\"\\n=== ARCH-LM(10) heteroskedasticity test ===\")\n",
        "display(pd.DataFrame(tbl_arch, columns=[\"Var\", \"ARCH stat\", \"p-value\"]).round(4))\n",
        "\n",
        "# Original scaling/outlier handling preserved.\n",
        "if y_df.abs().max().max() > 20:\n",
        "    y_df /= 100\n",
        "\n",
        "low = y_df.mean() - 3 * y_df.std()\n",
        "upp = y_df.mean() + 3 * y_df.std()\n",
        "y_df = y_df.clip(lower=low, upper=upp, axis=1)\n",
        "\n",
        "m_z = StandardScaler().fit_transform(m_df)\n",
        "\n",
        "\n",
        "def _beta(y, z):\n",
        "    \"\"\"Macro loading per maturity: yield_maturity ~ const + standardized macro variables.\"\"\"\n",
        "    return {c: OLS(y[c].values, add_constant(z)).fit().params for c in y}\n",
        "\n",
        "\n",
        "def _pca(y):\n",
        "    \"\"\"First principal component of the yield curve.\"\"\"\n",
        "    return PCA(1, random_state=SEED).fit_transform(y).ravel()\n",
        "\n",
        "\n",
        "def _sim(n, x0, z, beta, par, lb=-2):\n",
        "    \"\"\"\n",
        "    Macro-augmented jump-diffusion simulation.\n",
        "\n",
        "    This is the original stochastic simulation structure.\n",
        "    \"\"\"\n",
        "    k, sig, lam, jm, js, th0, th1, th2 = par\n",
        "    th = np.r_[np.repeat(th0, 50), np.repeat(th1, 100), np.repeat(th2, n - 150)]\n",
        "\n",
        "    x = np.empty(n)\n",
        "    x[0] = x0\n",
        "\n",
        "    b = np.vstack([v[1:] for v in beta.values()]).mean(0)\n",
        "    mac = z @ b * 0.02\n",
        "\n",
        "    for t in range(1, n):\n",
        "        j = rng.normal(jm, js) if rng.random() < lam else 0\n",
        "        x[t] = (\n",
        "            x[t - 1]\n",
        "            + k * (th[t] - x[t - 1])\n",
        "            + sig * rng.normal()\n",
        "            + j\n",
        "            + mac[t]\n",
        "        )\n",
        "        x[t] = max(x[t], lb)\n",
        "    return x\n",
        "\n",
        "\n",
        "def _kalman(x):\n",
        "    \"\"\"Kalman smoother/filter step used in the original code.\"\"\"\n",
        "    kf = KalmanFilter(dim_x=1, dim_z=1)\n",
        "    kf.x = np.array([[x[0]]])\n",
        "    kf.F = kf.H = np.array([[1.0]])\n",
        "    kf.P *= 1\n",
        "    kf.R *= 0.05\n",
        "    kf.Q *= 0.001\n",
        "\n",
        "    out = []\n",
        "    for v in x:\n",
        "        kf.predict()\n",
        "        kf.update([[v]])\n",
        "        out.append(kf.x[0, 0])\n",
        "    return np.array(out)\n",
        "\n",
        "\n",
        "beta = _beta(y_df, m_z)\n",
        "pca = _pca(y_df)\n",
        "\n",
        "print(\"\\n=== beta_hat macro loading per maturity ===\")\n",
        "for maturity, coef in beta.items():\n",
        "    print(f\"{maturity:>5}: {coef[1]:+.4f}\")\n",
        "\n",
        "pca = _pca(y_df)\n",
        "theta0, theta1, theta2 = pca[:50].mean(), pca[50:150].mean(), pca[150:].mean()\n",
        "\n",
        "x0 = [0.15, 0.015, 0.005, 0.10, 0.05, theta0, theta1, theta2]\n",
        "bnd = [\n",
        "    (1e-4, 1),\n",
        "    (1e-4, 0.05),\n",
        "    (0, 0.1),\n",
        "    (-0.5, 0.5),\n",
        "    (1e-4, 0.2),\n",
        "    (-5, 5),\n",
        "    (-5, 5),\n",
        "    (-5, 5),\n",
        "]\n",
        "\n",
        "obj = lambda p: ((_sim(len(pca), pca[0], m_z, beta, p) - pca) ** 2).sum()\n",
        "\n",
        "psihat = minimize(\n",
        "    obj,\n",
        "    x0,\n",
        "    bounds=bnd,\n",
        "    method=\"L-BFGS-B\",\n",
        "    options={\"maxiter\": 500},\n",
        ").x\n",
        "\n",
        "S = _sim(len(pca), pca[0], m_z, beta, psihat)\n",
        "S_sm = _kalman(S)\n",
        "\n",
        "final = pd.Series(0.7 * pca + 0.3 * S_sm, index=df.index, name=\"Final SR\")\n",
        "\n",
        "# -----------------------------\n",
        "# Robustness: PCA/simulation weight\n",
        "# -----------------------------\n",
        "rows = []\n",
        "ws = np.linspace(0.50, 0.90, 19)\n",
        "\n",
        "for w in ws:\n",
        "    shadow = pd.Series(w * pca + (1 - w) * S_sm, index=df.index)\n",
        "    rm = []\n",
        "    for m in ylds:\n",
        "        r = OLS(y_df[m], add_constant(shadow)).fit()\n",
        "        rm.append(np.sqrt(np.mean(r.resid**2)) * 100)\n",
        "    rows.append([w, np.mean(rm), np.std(rm)])\n",
        "\n",
        "rob = pd.DataFrame(rows, columns=[\"w_PCA\", \"mean_RMSE_bp\", \"sd_RMSE_bp\"])\n",
        "print(\"\\n=== Robustness to PCA/simulated weighting ===\")\n",
        "display(rob.round(2))\n",
        "\n",
        "# -----------------------------\n",
        "# PCA scree plot and shadow-rate plot\n",
        "# -----------------------------\n",
        "ev = PCA().fit(y_df).explained_variance_ratio_\n",
        "\n",
        "plt.figure(figsize=(5, 3))\n",
        "plt.bar(range(1, len(ev) + 1), ev * 100)\n",
        "plt.ylabel(\"% variance\")\n",
        "plt.xlabel(\"PC\")\n",
        "plt.title(\"Yield curve PCA scree\")\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(10, 4))\n",
        "final.plot(label=\"MAJD final SR\")\n",
        "pd.Series(pca, index=df.index).plot(alpha=0.4, label=\"PCA\")\n",
        "plt.axhline(0, color=\"k\", lw=0.5)\n",
        "plt.legend()\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# -----------------------------\n",
        "# Comparison with Wu-Xia / benchmark SR in the master workbook\n",
        "# -----------------------------\n",
        "start, end = \"2009-01-01\", \"2022-08-01\"\n",
        "alpha = 0.02\n",
        "\n",
        "ewma = final.ewm(alpha=alpha).mean().loc[start:end]\n",
        "wu = df[\"SR US\"].loc[start:end]\n",
        "\n",
        "plt.figure(figsize=(10, 4))\n",
        "ewma.plot(label=\"MAJD\", lw=2)\n",
        "wu.plot(label=\"WX\", lw=1.5, ls=\"--\")\n",
        "plt.title(\"US Shadow Rate\")\n",
        "plt.ylabel(\"%\")\n",
        "plt.axhline(0, color=\"k\", lw=0.5)\n",
        "plt.legend()\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "# -----------------------------\n",
        "# In-sample cross-section RMSE\n",
        "# -----------------------------\n",
        "rows = []\n",
        "for m in ylds:\n",
        "    r1 = OLS(y_df[m], add_constant(final)).fit()\n",
        "    r2 = OLS(y_df[m], add_constant(df[\"SR US\"])).fit()\n",
        "    rows.append([\n",
        "        m,\n",
        "        np.sqrt(np.mean(r1.resid**2)) * 100,\n",
        "        np.sqrt(np.mean(r2.resid**2)) * 100,\n",
        "    ])\n",
        "\n",
        "cs_rmse = pd.DataFrame(rows, columns=[\"Maturity\", \"RMSE_MAJD_bp\", \"RMSE_WX_bp\"])\n",
        "print(\"\\n=== In-sample cross-section RMSE ===\")\n",
        "display(cs_rmse.round(2))\n",
        "\n",
        "# -----------------------------\n",
        "# Out-of-sample RMSE\n",
        "# -----------------------------\n",
        "TEST_START = \"2023-01-01\"\n",
        "HMAX = 12\n",
        "train = final.loc[:TEST_START]\n",
        "test_idx = final.loc[TEST_START:].index\n",
        "\n",
        "if len(test_idx) > HMAX:\n",
        "    ar = AutoReg(train, lags=1, old_names=False).fit()\n",
        "    fc = ar.predict(start=len(train), end=len(train) + len(test_idx) - 1)\n",
        "    fc.index = test_idx\n",
        "\n",
        "    rows = []\n",
        "    for h in range(1, HMAX + 1):\n",
        "        idx = test_idx[h - 1:]\n",
        "        f = fc.shift(h - 1).loc[idx]\n",
        "\n",
        "        for m in ylds:\n",
        "            r = OLS(y_df[m].loc[train.index], add_constant(final.loc[train.index])).fit()\n",
        "            yhat = r.predict(add_constant(f))\n",
        "            rmse = np.sqrt(np.mean((y_df[m].loc[idx] - yhat) ** 2)) * 100\n",
        "            rows.append([m, h, rmse])\n",
        "\n",
        "    oos_df = (\n",
        "        pd.DataFrame(rows, columns=[\"Maturity\", \"h\", \"RMSE_bp\"])\n",
        "        .pivot(index=\"Maturity\", columns=\"h\", values=\"RMSE_bp\")\n",
        "        .reindex(ylds)\n",
        "    )\n",
        "\n",
        "    print(\"\\n=== OOS RMSE (bp) - forecast horizon h = 1...12 months ===\")\n",
        "    display(oos_df.round(2))\n",
        "else:\n",
        "    print(\"\\nOOS RMSE skipped: not enough post-TEST_START observations.\")\n",
        "\n",
        "# -----------------------------\n",
        "# Save generated shadow-rate series\n",
        "# -----------------------------\n",
        "shadow_csv = OUTPUT_DIR / \"shadow_rate_us.csv\"\n",
        "shadow_xlsx = OUTPUT_DIR / \"shadow_rate_us.xlsx\"\n",
        "\n",
        "final.to_csv(shadow_csv, index_label=\"Date\")\n",
        "final.to_excel(shadow_xlsx, sheet_name=\"US SR\")\n",
        "\n",
        "print(f\"\\nShadow-rate series written to: {shadow_csv.resolve()}\")\n",
        "print(f\"Rows written: {len(final):,}\")\n",
        "\n",
        "\n",
        "# =============================================================================\n",
        "# 3. Cascaldi-Garcia and Galvao style monthly VAR\n",
        "#    Data now come from:\n",
        "#       - Database_CG-G.mat inside the CGG zip\n",
        "#       - master workbook Wu-Xia series\n",
        "#       - generated final MAJD series from Section 2\n",
        "#    Original methodology preserved.\n",
        "# =============================================================================\n",
        "\n",
        "WORK_DIR = OUTPUT_DIR / \"_cgg_zip_extracted\"\n",
        "WORK_DIR.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "with zipfile.ZipFile(CGG_ZIP, \"r\") as z:\n",
        "    z.extractall(WORK_DIR)\n",
        "\n",
        "mat_files = list(WORK_DIR.rglob(\"Database_CG-G.mat\"))\n",
        "if not mat_files:\n",
        "    raise FileNotFoundError(\"Database_CG-G.mat not found inside the CGG zip.\")\n",
        "\n",
        "mat = sio.loadmat(mat_files[0])\n",
        "\n",
        "START_M = \"2008-01\"\n",
        "END_M = \"2015-12\"\n",
        "p = 3\n",
        "H_IRF = 36\n",
        "BOOT = 500\n",
        "\n",
        "qidx = pd.date_range(\"1975-03-31\", periods=mat[\"RGDP\"].shape[0], freq=\"Q-DEC\")\n",
        "\n",
        "# Replacement for the old FRED WSHOSHO call:\n",
        "# use the Wu-Xia / SR US sheet from the master workbook.\n",
        "wx_mo = ser[\"SR\"][[\"SR US\"]].rename(columns={\"SR US\": \"SHADOW\"}).resample(\"M\").mean()\n",
        "\n",
        "# Replacement for the old \"gia cascaldi & Galvao analisi.xlsx\":\n",
        "# use the generated MAJD shadow rate produced above.\n",
        "sr_mo = final.rename(\"SHADOW\").resample(\"M\").mean()\n",
        "\n",
        "# Original replacement logic preserved:\n",
        "# start from Wu-Xia and overwrite/add MAJD months where MAJD is available.\n",
        "# Reindex to the union first so modern pandas does not raise a KeyError\n",
        "# when the generated MAJD series extends beyond the Wu-Xia sample.\n",
        "shadow_my_mo = wx_mo.reindex(wx_mo.index.union(sr_mo.index)).sort_index()\n",
        "shadow_my_mo.loc[sr_mo.index, \"SHADOW\"] = sr_mo.to_numpy()\n",
        "\n",
        "macro_vars = [\n",
        "    \"LTFP2\",\n",
        "    \"RPCE\",\n",
        "    \"EBPm\",\n",
        "    \"RVOL1m\",\n",
        "    \"JLN1m\",\n",
        "    \"RGDP\",\n",
        "    \"RINV\",\n",
        "    \"RHOURS\",\n",
        "    \"RDEF\",\n",
        "    \"RSP500\",\n",
        "]\n",
        "\n",
        "df_q = pd.DataFrame(\n",
        "    {v: mat[v].ravel() for v in macro_vars},\n",
        "    index=qidx,\n",
        ")\n",
        "\n",
        "macro_mo = df_q.resample(\"M\").last().interpolate(method=\"linear\")\n",
        "\n",
        "df_wx = pd.concat([macro_mo, wx_mo], axis=1).loc[START_M:END_M].dropna()\n",
        "df_my = pd.concat([macro_mo, shadow_my_mo], axis=1).loc[START_M:END_M].dropna()\n",
        "\n",
        "for d in (df_wx, df_my):\n",
        "    d[:] = (d - d.mean()) / d.std()\n",
        "\n",
        "res_wx = VAR(df_wx).fit(p)\n",
        "res_my = VAR(df_my).fit(p)\n",
        "\n",
        "\n",
        "def girf(res, shock=\"SHADOW\", target=\"RGDP\", H=H_IRF):\n",
        "    \"\"\"\n",
        "    Generalized impulse response function.\n",
        "\n",
        "    Original structure preserved.\n",
        "    \"\"\"\n",
        "    A = res.coefs\n",
        "    names = res.names\n",
        "    k = len(names)\n",
        "    p_lag = A.shape[0]\n",
        "\n",
        "    Sig = res.sigma_u.values\n",
        "    sidx = names.index(shock)\n",
        "    tidx = names.index(target)\n",
        "\n",
        "    shock_vec = Sig[:, sidx] / np.sqrt(Sig[sidx, sidx])\n",
        "\n",
        "    state = np.zeros((p_lag, k))\n",
        "    state[0] = shock_vec\n",
        "\n",
        "    out = [state[0, tidx]]\n",
        "\n",
        "    for _ in range(1, H + 1):\n",
        "        new = sum(A[i] @ state[i] for i in range(p_lag))\n",
        "        state = np.vstack([new, state[:-1]])\n",
        "        out.append(new[tidx])\n",
        "\n",
        "    return np.asarray(out)\n",
        "\n",
        "\n",
        "def simulate_var_manual(res, u):\n",
        "    \"\"\"\n",
        "    Simulate VAR with supplied residuals.\n",
        "\n",
        "    Original bootstrap simulation structure preserved.\n",
        "    \"\"\"\n",
        "    coefs = res.coefs\n",
        "    c = res.params.iloc[0].values\n",
        "    p_lag, k = coefs.shape[0], coefs.shape[1]\n",
        "    T = len(u)\n",
        "\n",
        "    y = np.zeros((T + p_lag, k))\n",
        "    y[:p_lag] = res.endog[:p_lag]\n",
        "\n",
        "    for t in range(p_lag, T + p_lag):\n",
        "        y[t] = c + sum(coefs[i] @ y[t - i - 1] for i in range(p_lag)) + u[t - p_lag]\n",
        "\n",
        "    return y[p_lag:]\n",
        "\n",
        "\n",
        "def block_boot_girf(res, B=BOOT, block=3, H=H_IRF):\n",
        "    resid = res.resid.values\n",
        "    T = resid.shape[0]\n",
        "    out = np.empty((B, H + 1))\n",
        "\n",
        "    for b in range(B):\n",
        "        idx = []\n",
        "        while len(idx) < T:\n",
        "            s = rng.integers(0, T - block)\n",
        "            idx.extend(range(s, s + block))\n",
        "\n",
        "        u_b = resid[np.array(idx[:T])]\n",
        "\n",
        "        fit = VAR(\n",
        "            pd.DataFrame(\n",
        "                simulate_var_manual(res, u_b),\n",
        "                columns=res.names,\n",
        "            )\n",
        "        ).fit(p)\n",
        "\n",
        "        out[b] = girf(fit, H=H)\n",
        "\n",
        "    return np.percentile(out, [5, 16, 84, 95], axis=0)\n",
        "\n",
        "\n",
        "g_wx = girf(res_wx)\n",
        "g_my = girf(res_my)\n",
        "band_wx = block_boot_girf(res_wx)\n",
        "\n",
        "m = np.arange(H_IRF + 1) / 12\n",
        "\n",
        "plt.figure(figsize=(8, 4))\n",
        "plt.plot(m, g_wx, label=\"WX\")\n",
        "plt.plot(m, g_my, \"--\", label=\"MAJD\")\n",
        "plt.fill_between(m, band_wx[1], band_wx[2], alpha=0.15)\n",
        "plt.fill_between(m, band_wx[0], band_wx[3], alpha=0.07)\n",
        "plt.axhline(0)\n",
        "plt.xlabel(\"years\")\n",
        "plt.ylabel(\"% dev\")\n",
        "plt.title(\"RGDP GIRF (monthly VAR, 1 sigma shadow shock)\")\n",
        "plt.legend()\n",
