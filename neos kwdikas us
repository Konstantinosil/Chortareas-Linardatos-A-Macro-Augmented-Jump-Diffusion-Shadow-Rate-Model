        "# -----------------------------\n",
        "# Rolling forecast and Diebold-Mariano\n",
        "# -----------------------------\n",
        "h = 12\n",
        "start_roll = 40\n",
        "rmse_wx, rmse_my = [], []\n",
        "\n",
        "for t in range(start_roll, len(df_wx) - h):\n",
        "    mod_wx = VAR(df_wx.iloc[:t]).fit(p)\n",
        "    mod_my = VAR(df_my.iloc[:t]).fit(p)\n",
        "\n",
        "    f_wx = mod_wx.forecast(df_wx.values[t - p:t], h)[-1, mod_wx.names.index(\"RGDP\")]\n",
        "    f_my = mod_my.forecast(df_my.values[t - p:t], h)[-1, mod_my.names.index(\"RGDP\")]\n",
        "\n",
        "    y_obs = df_wx[\"RGDP\"].iloc[t + h - 1]\n",
        "\n",
        "    rmse_wx.append((y_obs - f_wx) ** 2)\n",
        "    rmse_my.append((y_obs - f_my) ** 2)\n",
        "\n",
        "rmse_wx = np.asarray(rmse_wx)\n",
        "rmse_my = np.asarray(rmse_my)\n",
        "\n",
        "print(\n",
        "    f\"12-month RMSE  WX={np.sqrt(rmse_wx.mean()):.3f}, \"\n",
        "    f\"MAJD={np.sqrt(rmse_my.mean()):.3f}\"\n",
        ")\n",
        "\n",
        "d = rmse_wx - rmse_my\n",
        "L = 3\n",
        "block_means = np.array([d[i::L].mean() for i in range(L)])\n",
        "var_d = L * block_means.var(ddof=1) / len(d)\n",
        "dm = d.mean() / np.sqrt(var_d)\n",
        "print(f\"Diebold-Mariano t-stat (positive favours MAJD): {dm:.2f}\")\n",
        "\n",
        "# -----------------------------\n",
        "# DM robustness with AIC/BIC lags and horizons\n",
        "# -----------------------------\n",
        "from scipy.stats import norm\n",
        "\n",
        "\n",
        "def hac_var(d, L):\n",
        "    \"\"\"\n",
        "    Fixed-block HAC variance estimator.\n",
        "    \"\"\"\n",
        "    d = np.asarray(d)\n",
        "    gamma0 = np.var(d, ddof=1)\n",
        "    s = gamma0\n",
        "\n",
        "    for ell in range(1, L + 1):\n",
        "        w = 1 - ell / (L + 1)\n",
        "        gamma = np.cov(d[:-ell], d[ell:], ddof=0)[0, 1]\n",
        "        s += 2 * w * gamma\n",
        "\n",
        "    return s / len(d)\n",
        "\n",
        "\n",
        "def rolling_msfe(df_wx, df_my, p_lag, h, target=\"RGDP\", L=3):\n",
        "    se_wx, se_my = [], []\n",
        "    start = max(p_lag + h + L, df_wx.shape[1] + 1)\n",
        "\n",
        "    for t in range(start, len(df_wx) - h):\n",
        "        m_wx = VAR(df_wx.iloc[:t]).fit(p_lag)\n",
        "        m_my = VAR(df_my.iloc[:t]).fit(p_lag)\n",
        "\n",
        "        f_wx = m_wx.forecast(df_wx.values[t - p_lag:t], h)[-1, m_wx.names.index(target)]\n",
        "        f_my = m_my.forecast(df_my.values[t - p_lag:t], h)[-1, m_my.names.index(target)]\n",
        "\n",
        "        y_obs = df_wx[target].iloc[t + h - 1]\n",
        "\n",
        "        se_wx.append((y_obs - f_wx) ** 2)\n",
        "        se_my.append((y_obs - f_my) ** 2)\n",
        "\n",
        "    se_wx = np.asarray(se_wx)\n",
        "    se_my = np.asarray(se_my)\n",
        "\n",
        "    diff = se_wx - se_my\n",
        "    dm_statistic = diff.mean() / np.sqrt(hac_var(diff, L))\n",
        "\n",
        "    return {\n",
        "        \"h\": h,\n",
        "        \"RMSE_WX\": np.sqrt(se_wx.mean()),\n",
        "        \"RMSE_MAJD\": np.sqrt(se_my.mean()),\n",
        "        \"DM_t\": dm_statistic,\n",
        "        \"p_value\": 2 * (1 - norm.cdf(abs(dm_statistic))),\n",
        "        \"N_forecasts\": len(diff),\n",
        "    }\n",
        "\n",
        "\n",
        "sel = VAR(df_wx).select_order(maxlags=6)\n",
        "p_aic = sel.aic\n",
        "p_bic = sel.bic\n",
        "\n",
        "print(\"Lag selected by AIC:\", p_aic)\n",
        "print(\"Lag selected by BIC:\", p_bic)\n",
        "\n",
        "rows = []\n",
        "for crit, p_sel in [(\"AIC\", p_aic), (\"BIC\", p_bic), (\"baseline_p3\", 3)]:\n",
        "    for h_i in [1, 3, 6, 12]:\n",
        "        r = rolling_msfe(df_wx, df_my, p_sel, h_i)\n",
        "        r[\"lag_rule\"] = crit\n",
        "        r[\"p\"] = p_sel\n",
        "        rows.append(r)\n",
        "\n",
        "robust_dm = pd.DataFrame(rows)\n",
        "\n",
        "print(\"\\n=== Robustness DM table ===\")\n",
        "display(robust_dm.round(3))\n",
        "\n",
        "robust_dm.to_excel(OUTPUT_DIR / \"dm_robustness_monthly.xlsx\", index=False)\n",
        "\n",
        "# -----------------------------\n",
        "# Robustness: p-sweep, blocks, subsamples, alternative targets\n",
        "# -----------------------------\n",
        "p_max = 12\n",
        "horizons = [1, 3, 6, 12]\n",
        "blocks = [3, 6]\n",
        "subsplits = [(\"2008-01\", \"2011-12\"), (\"2012-01\", \"2015-12\")]\n",
        "\n",
        "\n",
        "def hac_var_fixed_block(d, L):\n",
        "    \"\"\"fixed-block variance (Andrews style), as in the original robustness block.\"\"\"\n",
        "    if len(d) == 0:\n",
        "        return np.nan\n",
        "    block_means = np.array([d[i::L].mean() for i in range(L)])\n",
        "    return L * block_means.var(ddof=1) / len(d)\n",
        "\n",
        "\n",
        "def dm_stat(df_wx_in, df_my_in, target, p_lag, h_i, L_i):\n",
        "    rmse_wx_l, rmse_my_l = [], []\n",
        "    start = max(p_lag + h_i + L_i, df_wx_in.shape[1] + 1)\n",
        "\n",
        "    for t in range(start, len(df_wx_in) - h_i):\n",
        "        m_wx = VAR(df_wx_in.iloc[:t]).fit(p_lag)\n",
        "        m_my = VAR(df_my_in.iloc[:t]).fit(p_lag)\n",
        "\n",
        "        f_wx = m_wx.forecast(df_wx_in.values[t - p_lag:t], h_i)[-1, m_wx.names.index(target)]\n",
        "        f_my = m_my.forecast(df_my_in.values[t - p_lag:t], h_i)[-1, m_my.names.index(target)]\n",
        "\n",
        "        y_obs = df_wx_in[target].iloc[t + h_i - 1]\n",
        "\n",
        "        rmse_wx_l.append((y_obs - f_wx) ** 2)\n",
        "        rmse_my_l.append((y_obs - f_my) ** 2)\n",
        "\n",
        "    if not rmse_wx_l:\n",
        "        return np.nan, np.nan, np.nan, 0\n",
        "\n",
        "    se_wx = np.asarray(rmse_wx_l)\n",
        "    se_my = np.asarray(rmse_my_l)\n",
        "    d_diff = se_wx - se_my\n",
        "\n",
        "    v = hac_var_fixed_block(d_diff, L_i)\n",
        "    t_dm = d_diff.mean() / np.sqrt(v) if v > 0 else np.nan\n",
        "\n",
        "    return np.sqrt(se_wx.mean()), np.sqrt(se_my.mean()), t_dm, len(d_diff)\n",
        "\n",
        "\n",
        "records = []\n",
        "\n",
        "# p-sweep\n",
        "for p_i in range(1, p_max + 1):\n",
        "    for h_i in horizons:\n",
        "        rw, rm, tdm, n = dm_stat(df_wx, df_my, \"RGDP\", p_i, h_i, 3)\n",
        "        records.append([\"p-sweep\", \"full\", \"RGDP\", p_i, h_i, 3, rw, rm, tdm, n])\n",
        "\n",
        "# block robustness\n",
        "for L_i in blocks:\n",
        "    rw, rm, tdm, n = dm_stat(df_wx, df_my, \"RGDP\", 3, 12, L_i)\n",
        "    records.append([\"block\", \"full\", \"RGDP\", 3, 12, L_i, rw, rm, tdm, n])\n",
        "\n",
        "# subsamples\n",
        "for a, b in subsplits:\n",
        "    dfx = df_wx.loc[a:b]\n",
        "    dfm = df_my.loc[a:b]\n",
        "    rw, rm, tdm, n = dm_stat(dfx, dfm, \"RGDP\", 3, 12, 3)\n",
        "    records.append([\"subsample\", f\"{a}-{b}\", \"RGDP\", 3, 12, 3, rw, rm, tdm, n])\n",
        "\n",
        "# alternative target\n",
        "for target in [\"RGDP\", \"RHOURS\"]:\n",
        "    rw, rm, tdm, n = dm_stat(df_wx, df_my, target, 3, 12, 3)\n",
        "    records.append([\"target\", \"full\", target, 3, 12, 3, rw, rm, tdm, n])\n",
        "\n",
        "rob = pd.DataFrame(\n",
        "    records,\n",
        "    columns=[\n",
        "        \"check\",\n",
        "        \"sample\",\n",
        "        \"target\",\n",
        "        \"p\",\n",
        "        \"h\",\n",
        "        \"block\",\n",
        "        \"RMSE_WX\",\n",
        "        \"RMSE_MAJD\",\n",
        "        \"DM_t\",\n",
        "        \"N\",\n",
        "    ],\n",
        ")\n",
        "\n",
        "rob[\"delta_RMSE\"] = rob[\"RMSE_WX\"] - rob[\"RMSE_MAJD\"]\n",
        "\n",
        "print(rob.round(3).to_string(index=False))\n",
        "\n",
        "\n",
